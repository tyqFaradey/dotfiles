{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "author": "Christian Angermann",
  "name": "Nightfox Themes - opaque / blurred",
  "themes": [
    {
			"name": "Everforest Blurred",
			"appearance": "dark",
			"style": {
	      "background.appearance": "blurred",
        "background": "#000000aa",
        "editor.background": "#00000000",
        "editor.gutter.background": "#00000000",
        "editor.line_number": "#cccccc33",

        "panel.background": "#00000000",
        "terminal.background": "#00000000",

        "tab_bar.background": "#0c0c0c33",
        "tab.inactive_background": "#0c0c0c33",
        "tab.active_background": "#00000000",

        "title_bar.background": "#000000aa",
        "toolbar.background": "#00000000",
        "status_bar.background": "#000000aa",

        "border": "#00000011W",
    		"border.variant": "#0c0c0c10",
    		"border.focused": "#0c0c0c10",
    		"border.selected": "#0c0c0c10",
    		"border.transparent": "#0c0c0c10",
    		"border.disabled": "#0c0c0c10",

        "editor.active_line_number": "#b2ce8a",


				"players": [
					{
						"cursor": "#d3c6aa",
						"selection": "#475258",
						"background": "#475258"
					}
				],
				"syntax": {
					"attribute": {
						"color": "#dbbc7f",
						"font_style": null,
						"font_weight": null
					},
					"constant": {
						"color": "#d699b6",
						"font_style": null,
						"font_weight": null
					},
					"constructor": {
						"color": "#d699b6",
						"font_style": null,
						"font_weight": null
					},
					"comment": {
						"color": "#859289",
						"font_style": "italic",
						"font_weight": null
					},
					"function": {
						"color": "#b2ce8a",
						"font_style": null,
						"font_weight": null
					},
					"keyword": {
						"color": "#f08385",
						"font_style": null,
						"font_weight": 600
					},
					"number": {
						"color": "#d699b6",
						"font_style": null,
						"font_weight": null
					},
					"operator": {
						"color": "#e69875",
						"font_style": null,
						"font_weight": null
					},
					"property": {
						"color": "#83c092",
						"font_style": null,
						"font_weight": null
					},
					"string": {
						"color": "#83c092",
						"font_style": null,
						"font_weight": null
					},
					"string.escape": {
						"color": "#98c379",
						"font_style": null,
						"font_weight": null
					},
					"type": {
						"color": "#dbbc7f",
						"font_style": null,
						"font_weight": null
					}
				}
			}
		}
  ]
}
