{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "restore_on_file_reopen": false,
  "close_on_file_delete": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "format_on_save": "on",

  "languages": {
    "Python": {
      "tab_size": 4
    },
    "CSS": {
      "tab_size": 2
    },
    "SCSS": {
      "tab_size": 2
    },
    "HTML": {
      "tab_size": 2
    },
    "QML": {
      "tab_size": 2
    }
  },

  "theme": {
    "mode": "dark",
    "light": "Pure Glass",
    "dark": "Everforest Blurred",
  },

  "icon_theme": {
    "mode": "light",
    "light": "Monospace Icon Theme - Dark",
    "dark": "Symbols Icon Theme",
  },

  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "ui_font_weight": 100,
  "ui_font_size": 17,

  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_weight": 400,
  "buffer_font_size": 17,
  "buffer_line_height": "standard",

  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_weight": 400,
    "font_size": 15,
    "line_height": "standard",
  },

  "cursor_blink": true,
  "cursor_shape": "bar",
  "current_line_highlight": "none",
  "show_whitespaces": "none",

  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  "relative_line_numbers": "disabled",

  "indent_guides": {
    "enabled": false,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "fixed",
    "background_coloring": "disabled",
  },

  "minimap": {
    "show": "never",
  },

  "title_bar": {
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_menus": false,
  },

  "status_bar": {
    "experimental.show": false,
    "line_endings_button": true,
  },

  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },

  "project_panel": {
    "dock": "right",
    "default_width": 200,
    "hide_root": true,
    "sort_mode": "directories_first",
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,

    "drag_and_drop": true,
    "folder_icons": false,
    "scrollbar": {
      "show": "never",
    },
  },

  "scrollbar": {
    "show": "never",
  },

  "edit_predictions": {
    "mode": "subtle",
    "enabled_in_text_threads": true,
  },
  "show_edit_predictions": true,

  "file_scan_exclusions": ["**/__pycache__", "**/.git", "**/.venv"],
}
