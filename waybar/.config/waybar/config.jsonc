{
  "reload_style_on_change": true,
  "toggle": true,
  "layer": "top",
  "position": "left",
  "margin-top": 6,
  "margin-bottom": 6,
  "margin-left": 6,
  "margin-right": 0,
  "spacing": 0,
  "include": ["~/.config/waybar/modules.jsonc"],
  "modules-left": ["clock"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "pulseaudio",
    "backlight",
    "bluetooth",
    "network",
    "battery",
  ],
}
